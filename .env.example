# Copia este archivo como .env.local y rellena los valores.

# Base de datos Postgres (Neon). Se obtiene del panel de Neon.
DATABASE_URL="postgresql://usuario:clave@host/basedatos?sslmode=require"

# Clave de Google Gemini (opcional; la redacción con IA no funciona sin ella).
GEMINI_API_KEY="MY_GEMINI_API_KEY"
